{
   "name": ".",
   "version": "0.0.1",
   "description": "Awesome project developed with TypeORM.",
   "type": "commonjs",
   "devDependencies": {
      "@types/node": "^16.11.10",
      "ts-node": "10.7.0",
      "tslib": "^2.5.0",
      "typescript": "4.5.2"
   },
   "dependencies": {
      "body-parser": "^1.19.1",
      "express": "^4.17.2",
      "pg": "^8.4.0",
      "reflect-metadata": "^0.1.13",
      "typeorm": "https://github.com/hlcianfagna/typeorm#cratedb"
   },
   "scripts": {
      "start": "ts-node src/index.ts",
      "insert": "ts-node src/insert.ts",
      "query": "typeorm-ts-node-commonjs query --dataSource src/data-source.ts 'SELECT * FROM \"user\"'",
      "typeorm": "typeorm-ts-node-commonjs",
      "test": "npm run insert && npm run query",
      "build-typeorm": "cd node_modules/typeorm && npm install && npm run package"
   }
}
